CORS_ORIGINS=["http://localhost:3000"]

# Must be a Postgres with the pgvector extension available (the first
# embeddings migration runs `CREATE EXTENSION IF NOT EXISTS vector`).
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/interview_stack

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=interview-stack-audio
# Optional: point at a local S3-compatible endpoint (e.g. MinIO) for dev/testing
AWS_S3_ENDPOINT_URL=

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI_PROVIDER=mock (default) needs no credentials. Set to "openai" and
# provide OPENAI_API_KEY to use a real provider.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Must match OPENAI_EMBEDDING_MODEL's actual output size (1536 for
# text-embedding-3-small); changing it requires a migration.
EMBEDDING_DIMENSIONS=1536
